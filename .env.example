APP_NAME="Prime CRM"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://crmprime.online

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ─── Logging (use 'warning' in production) ────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ─── Database ─────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=main
DB_USERNAME=root
DB_PASSWORD=

# ─── Session (use 'database' in production, secure cookies) ──
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

# ─── Broadcasting / Filesystem / Queue ────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# ─── Cache ────────────────────────────────────────────────────
CACHE_STORE=database

# ─── Redis (optional, recommended for cache/queue at scale) ──
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Mail ─────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@crmprime.online"
MAIL_FROM_NAME="${APP_NAME}"

# ─── AWS (if using S3 for file storage) ──────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Twilio (TURN/ICE servers for video calls) ───────────────
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=

# ─── GIF Provider (giphy or tenor) ───────────────────────────
GIF_PROVIDER=giphy
GIPHY_API_KEY=
TENOR_API_KEY=
TENOR_CLIENT_KEY=

# ─── AI Engine (OpenAI) ──────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Frontend ─────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
