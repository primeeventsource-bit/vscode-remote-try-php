{
    "name": "prime/crm",
    "type": "project",
    "description": "Prime CRM Laravel Backend",
    "keywords": ["crm", "laravel"],
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0",
        "laravel/tinker": "^2.10",
        "league/flysystem-aws-s3-v3": "^3.0",
        "livewire/livewire": "^3.0",
        "minishlink/web-push": "^10.0",
        "twilio/sdk": "*"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.9",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "Database\\Seeders\\": "database/seeders/",
            "Database\\Factories\\": "database/factories/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php -r \"foreach (['bootstrap/cache','storage/logs','storage/framework/cache','storage/framework/sessions','storage/framework/views'] as \\$dir) { if (!is_dir(\\$dir)) { mkdir(\\$dir, 0775, true); } }\"",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-install-cmd": [
            "@php -r \"foreach (['bootstrap/cache','storage/logs','storage/framework/cache','storage/framework/sessions','storage/framework/views'] as \\$dir) { if (!is_dir(\\$dir)) { mkdir(\\$dir, 0775, true); } }\""
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        },
        "platform": {
            "php": "8.4.19"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
